# ---- Embedded data store (SurrealDB + LibSQL; no Docker/Postgres/Redis) ----
# Where Veylin keeps its local database files. Defaults to ~/.veylin in
# desktop builds; ./data is convenient for local development.
VEYLIN_DATA_DIR=./data

# Single-user desktop mode: skips authentication entirely. This is the default
# for the packaged desktop app where the server only listens on localhost.
# SET THIS TO 0 (and configure AUTH_SECRET below) for any shared/hosted deploy.
VEYLIN_DESKTOP_AUTH=1

# ---- Models ----
# Configure models in the UI (Settings → Models) or via models.local.json under
# VEYLIN_DATA_DIR. Optional dev fallback when no catalog file exists:
VEYLIN_API_KEY=
VEYLIN_BASE_URL=https://api.openai.com/v1
VEYLIN_MODEL=gpt-4o-mini
# Comma-separated catalog ids with vision support, or * for all models.
# VEYLIN_VISION_MODELS=default
# VEYLIN_REQUIRE_USER_MODEL_SETTINGS=1

# Embeddings run locally by default (offline). Set to an API provider to offload.
EMBEDDING_PROVIDER=local

# ---- Auth (required for shared/hosted deployments) ----
# When VEYLIN_DESKTOP_AUTH=0, you MUST set a strong AUTH_SECRET. Without it the
# server falls back to no-auth mode, which is only safe on a trusted localhost.
# AUTH_SECRET=change-me-to-a-long-random-string
# AUTH_BASE_URL=http://localhost:8787
# Identity adapter: local (default) | oidc | webhook | desktop
# IDENTITY_PROVIDER=local
# AUTH_REQUIRE_EMAIL_VERIFICATION=0
# IDENTITY_WEBHOOK_URL=https://idp.example/session
# IDENTITY_OIDC_USERINFO_URL=https://idp.example/userinfo
# IDENTITY_OIDC_INTROSPECTION_URL=
# IDENTITY_OIDC_CLIENT_ID=
# IDENTITY_OIDC_CLIENT_SECRET=
# Optional audit sink fallback (prefer Settings → Business → Audit webhook in UI)
# AUDIT_WEBHOOK_URL=https://siem.example/ingest
# VEYLIN_RBAC_FILTER_TOOLS=0

PORT=8787

# ---- Local dev (`npm run dev`) ----
# Free ports 8787/5174 before starting (set 0 to skip).
# VEYLIN_DEV_CLEAN_PORTS=1
# Defer MCP connect until after listen (npm run dev sets this by default).
# VEYLIN_LAZY_MCP_BOOT=1
# Reload agent.yaml on each chat (npm run dev sets this by default).
# VEYLIN_HOT_RELOAD_AGENTS=1
# Startup profiler: VEYLIN_PROFILE_STARTUP=1 (server) / VITE_VEYLIN_PROFILE_STARTUP=1 (web)
# Hosted deploy CORS (ignored when VEYLIN_DESKTOP_AUTH=1):
# CORS_ALLOWED_ORIGINS=http://localhost:5174,https://your-domain.example

# ---- MCP (optional dev/bootstrap) ----
# JSON array of remote MCP servers inserted on startup when not already in DB.
# VEYLIN_MCP_SERVERS=[{"name":"compass","transport":"sse","url":"https://mcp.compass-work.com/mcp/"}]
# Optional headers: {"name":"compass","transport":"sse","url":"https://...","headers":{"Authorization":"Bearer ..."}}

# Optional tracing (Langfuse)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_HOST=   # alias for LANGFUSE_BASE_URL
# LANGFUSE_ENVIRONMENT=
# LANGFUSE_RELEASE=

# ---- Context engineering (compaction & prompt layering) ----
# Autocompact when estimated tokens ≥ effectiveWindow − 13k (Claude Code).
# effectiveWindow = contextWindow − reservedOutput (default 20k).
# Optional test overrides (unset in production):
# VEYLIN_AUTOCOMPACT_PCT=5          # percent (or 0.05) of effective window — testing only
# VEYLIN_AUTOCOMPACT_BUFFER=13000
# VEYLIN_AUTOCOMPACT_WINDOW=8000    # clamp window for easier local testing
# VEYLIN_COMPACT_RESERVED_OUTPUT=20000
# VEYLIN_TOKEN_LIMIT=1048576        # force TokenLimiter / compact window (test fixture)
# Microcompact: keep full tool results for the last N assistant tool rounds.
# VEYLIN_MC_KEEP_ROUNDS=3
# LLM compaction summary max tokens.
# VEYLIN_COMPACT_MAX_TOKENS=2000
# Optional reply style: default | explanatory
# VEYLIN_OUTPUT_STYLE=default
