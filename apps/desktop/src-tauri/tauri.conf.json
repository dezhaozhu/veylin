{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Veylin",
  "version": "0.1.23",
  "identifier": "com.veylin.app",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run -w @veylin/web dev",
    "beforeBuildCommand": "node scripts/before-build.mjs"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Veylin",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 600,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 18 },
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"],
    "externalBin": ["binaries/veylin-server"],
    "resources": {
      "../../server/dist/sidecar": "sidecar"
    }
  },
  "plugins": {
    "shell": {
      "open": false
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM1M0U5ODRGODgyNUZFODEKUldTQi9pV0lUNWcrTmN3dGlHMG1qd25lck5rRzVFQmFheWhHdjJJOTJKQjlBUEgveVQ5VncxaHcK",
      "endpoints": [
        "https://github.com/dezhaozhu/veylin/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
