{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Veylin",
  "version": "0.1.0",
  "identifier": "com.veylin.app",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run -w @veylin/web dev",
    "beforeBuildCommand": "VITE_API_URL=http://127.0.0.1:8787 npm run -w @veylin/web build && npm run -w @veylin/server build:sidecar"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Veylin",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"],
    "externalBin": ["binaries/veylin-server"],
    "resources": {
      "../../server/dist/sidecar": "sidecar"
    }
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
